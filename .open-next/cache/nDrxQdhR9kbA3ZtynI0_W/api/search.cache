"id\":\"/docs/reporting-76\",\"page_id\":\"/docs/reporting\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/reporting#date-range-options\",\"content\":\"Custom start and end date\"},\"645\":{\"id\":\"/docs/sales\",\"page_id\":\"/docs/sales\",\"type\":\"page\",\"content\":\"Sales Hub\",\"breadcrumbs\":[\"Docs\"],\"tags\":[],\"url\":\"/docs/sales\"},\"646\":{\"id\":\"/docs/sales-0\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales\",\"content\":\"View, filter, and export your full sales history — appointments, payments, memberships, vouchers, products, and tips\"},\"647\":{\"id\":\"/docs/sales-1\",\"page_id\":\"/docs/sales\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/sales#daily-sales\",\"content\":\"Daily Sales\"},\"648\":{\"id\":\"/docs/sales-2\",\"page_id\":\"/docs/sales\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/sales#appointments\",\"content\":\"Appointments\"},\"649\":{\"id\":\"/docs/sales-3\",\"page_id\":\"/docs/sales\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/sales#sales-transactions\",\"content\":\"Sales Transactions\"},\"650\":{\"id\":\"/docs/sales-4\",\"page_id\":\"/docs/sales\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/sales#payments\",\"content\":\"Payments\"},\"651\":{\"id\":\"/docs/sales-5\",\"page_id\":\"/docs/sales\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/sales#memberships\",\"content\":\"Memberships\"},\"652\":{\"id\":\"/docs/sales-6\",\"page_id\":\"/docs/sales\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/sales#vouchers\",\"content\":\"Vouchers\"},\"653\":{\"id\":\"/docs/sales-7\",\"page_id\":\"/docs/sales\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/sales#products\",\"content\":\"Products\"},\"654\":{\"id\":\"/docs/sales-8\",\"page_id\":\"/docs/sales\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/sales#tips\",\"content\":\"Tips\"},\"655\":{\"id\":\"/docs/sales-9\",\"page_id\":\"/docs/sales\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/sales#client-profile\",\"content\":\"Client Profile\"},\"656\":{\"id\":\"/docs/sales-10\",\"page_id\":\"/docs/sales\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/sales#sale-details\",\"content\":\"Sale Details\"},\"657\":{\"id\":\"/docs/sales-11\",\"page_id\":\"/docs/sales\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/sales#quick-reference\",\"content\":\"Quick reference\"},\"658\":{\"id\":\"/docs/sales-12\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales\",\"content\":\"The Sales Hub is your complete record of everything that's been sold or paid for. Click **Sales** in the left menu and you'll see a sidebar with eight sections. Each one is focused on a different part of your business and has its own search, date filter, and **Export** button.\"},\"659\":{\"id\":\"/docs/sales-13\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#daily-sales\",\"content\":\"**Sales → Daily Sales**\"},\"660\":{\"id\":\"/docs/sales-14\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#daily-sales\",\"content\":\"Your end-of-day summary. Use the **Today*&#x2A;, &#x2A;*\\\\<*&#x2A;, and &#x2A;*>** buttons to pick any day and see a full breakdown of what happened.\"},\"661\":{\"id\":\"/docs/sales-15\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#daily-sales\",\"content\":\"The page is split into three parts:\"},\"662\":{\"id\":\"/docs/sales-16\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#daily-sales\",\"content\":\"**Transaction summary**\\nA table showing what was sold by item type (e.g., Service, Product), how many were sold, and the net total.\"},\"663\":{\"id\":\"/docs/sales-17\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#daily-sales\",\"content\":\"**Cash movement summary**\\nA breakdown of how payments were collected — showing each payment method (Cash, Online, Card, etc.) and the amount collected through each. Also shows the total **Payments collected** and how much of that was **tips**.\"},\"664\":{\"id\":\"/docs/sales-18\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#daily-sales\",\"content\":\"**Summary bar**\\nFour quick-view numbers at the bottom:\"},\"665\":{\"id\":\"/docs/sales-19\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#daily-sales\",\"content\":\"**Total Sales** — total revenue for the day\"},\"666\":{\"id\":\"/docs/sales-20\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#daily-sales\",\"content\":\"**Total Transactions** — number of completed transactions\"},\"667\":{\"id\":\"/docs/sales-21\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#daily-sales\",\"content\":\"**Sale Types** — how many different item types were sold\"},\"668\":{\"id\":\"/docs/sales-22\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#daily-sales\",\"content\":\"**Payment Methods** — how many different payment methods were used\"},\"669\":{\"id\":\"/docs/sales-23\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#appointments\",\"content\":\"**Sales → Appointments**\"},\"670\":{\"id\":\"/docs/sales-24\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#appointments\",\"content\":\"A full list of every appointment-based sale. Use this when you need to look up a specific service, client visit, or check what was charged and whether a discount was applied.\"},\"671\":{\"id\":\"/docs/sales-25\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#appointments\",\"content\":\"**Columns:** Sale ID · Client (name + phone) · Service · Sale Date · Team Member · Unit Price · Quantity · Discount · Total Price\"},\"672\":{\"id\":\"/docs/sales-26\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#appointments\",\"content\":\"Discounts show in red when applied. Search by client name or service, or filter by date range. Click **Export** to download as CSV.\"},\"673\":{\"id\":\"/docs/sales-27\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#sales-transactions\",\"content\":\"**Sales → Sales**\"},\"674\":{\"id\":\"/docs/sales-28\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#sales-transactions\",\"content\":\"Your complete transaction history across all sale types. By default it shows the last 30 days.\"},\"675\":{\"id\":\"/docs/sales-29\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#sales-transactions\",\"content\":\"**Columns:** Sale ID · Payment Date · Client · Team Members · Payment Method · Tips · Status · Amount\"},\"676\":{\"id\":\"/docs/sales-30\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#sales-transactions\",\"content\":\"The **Status** column shows either:\"},\"677\":{\"id\":\"/docs/sales-31\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#sales-transactions\",\"content\":\"**Completed** — the sale went through successfully\"},\"678\":{\"id\":\"/docs/sales-32\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#sales-transactions\",\"content\":\"**Voided** (red badge) — the sale was reversed after the fact\"},\"679\":{\"id\":\"/docs/sales-33\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#sales-transactions\",\"content\":\"Click any **Sale ID** to open the full Sale Details panel.\"},\"680\":{\"id\":\"/docs/sales-34\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#sales-transactions\",\"content\":\"Click any **Client name** to open their Client Profile.\"},\"681\":{\"id\":\"/docs/sales-35\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#payments\",\"content\":\"**Sales → Payments**\"},\"682\":{\"id\":\"/docs/sales-36\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#payments\",\"content\":\"Every payment transaction that was successfully collected — similar to Sales Transactions but focused on the payment side only. Voided sales are excluded here.\"},\"683\":{\"id\":\"/docs/sales-37\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#payments\",\"content\":\"**Columns:** Sale ID · Payment Date · Client · Team Members · Payment Method · Tips · Status · Amount\"},\"684\":{\"id\":\"/docs/sales-38\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#payments\",\"content\":\"Tips show in the Tips column when they were added to the sale. Search by client name or sale ID, or filter by date range.\"},\"685\":{\"id\":\"/docs/sales-39\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#memberships\",\"content\":\"**Sales → Memberships**\"},\"686\":{\"id\":\"/docs/sales-40\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#memberships\",\"content\":\"All membership packages that have been sold, with live session tracking.\"},\"687\":{\"id\":\"/docs/sales-41\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#memberships\",\"content\":\"**Columns:** Purchase Date · Client · Membership name · Service · Sessions (used / remaining with a progress bar) · Cost · Status\"},\"688\":{\"id\":\"/docs/sales-42\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#memberships\",\"content\":\"The **Status** shows either **Active** (sessions still available) or **Completed** (all sessions used). The progress bar makes it easy to see at a glance how far through a package a client is.\"},\"689\":{\"id\":\"/docs/sales-43\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#vouchers\",\"content\":\"**Sales → Vouchers**\"},\"690\":{\"id\":\"/docs/sales-44\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#vouchers\",\"content\":\"All vouchers that have been purchased or redeemed. Search by client name, voucher name, or voucher code. Filter by date range to narrow results.\"},\"691\":{\"id\":\"/docs/sales-45\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#products\",\"content\":\"**Sales → Products**\"},\"692\":{\"id\":\"/docs/sales-46\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#products\",\"content\":\"A record of every product sold, with live stock levels.\"},\"693\":{\"id\":\"/docs/sales-47\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#products\",\"content\":\"**Columns:** Sale ID · Product Name · Category · Brand · Quantity · Unit Price · Total Price · Current Stock · Sale Date · Status\"},\"694\":{\"id\":\"/docs/sales-48\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#products\",\"content\":\"The **Current Stock** column shows a warning icon (⚠) when stock is running low. The **Status** badge will show **Low Stock** to flag items that need reordering.\"},\"695\":{\"id\":\"/docs/sales-49\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#products\",\"content\":\"Search by product name, SKU, barcode, or category.\"},\"696\":{\"id\":\"/docs/sales-50\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#tips\",\"content\":\"**Sales → Tips**\"},\"697\":{\"id\":\"/docs/sales-51\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#tips\",\"content\":\"Every tip that's been collected, attributed to the staff member who received it.\"},\"698\":{\"id\":\"/docs/sales-52\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#tips\",\"content\":\"**Columns:** Sale ID · Tip Amount · Staff Member · Payment Method · Sale Total · Date\"},\"699\":{\"id\":\"/docs/sales-53\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#tips\",\"content\":\"Search by staff name, payment method, or sale ID. Filter by date range.\"},\"700\":{\"id\":\"/docs/sales-54\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#client-profile\",\"content\":\"Anywhere you see a **client name** shown as a blue link (in Sales Transactions, Payments, etc.), you can click it to open that client's full profile in a panel on the right.\"},\"701\":{\"id\":\"/docs/sales-55\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#client-profile\",\"content\":\"The profile is split into two parts:\"},\"702\":{\"id\":\"/docs/sales-56\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#client-profile\",\"content\":\"**Left — Client details**\"},\"703\":{\"id\":\"/docs/sales-57\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#client-profile\",\"content\":\"Name, phone, and email\"},\"704\":{\"id\":\"/docs/sales-58\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#client-profile\",\"content\":\"**Edit client** — update their contact details\"},\"705\":{\"id\":\"/docs/sales-59\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#client-profile\",\"content\":\"**Add review** — add an internal note or review about the client\"},\"706\":{\"id\":\"/docs/sales-60\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#client-profile\",\"content\":\"Date of birth (optional)\"},\"707\":{\"id\":\"/docs/sales-61\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#client-profile\",\"content\":\"Date the client was created in the system\"},\"708\":{\"id\":\"/docs/sales-62\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#client-profile\",\"content\":\"**Middle — Navigation tabs**\\nSwitch between different views of the client's history:\"},\"709\":{\"id\":\"/docs/sales-63\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#client-profile\",\"content\":\"Tab\"},\"710\":{\"id\":\"/docs/sales-64\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#client-profile\",\"content\":\"What it shows\"},\"711\":{\"id\":\"/docs/sales-65\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#client-profile\",\"content\":\"Appointments\"},\"712\":{\"id\":\"/docs/sales-66\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#client-profile\",\"content\":\"All appointments with status badges (Paid, Scheduled, No Show)\"},\"713\":{\"id\":\"/docs/sales-67\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#client-profile\",\"content\":\"Sales\"},\"714\":{\"id\":\"/docs/sales-68\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#client-profile\",\"content\":\"All completed sales with service, total, and a View Details button\"},\"715\":{\"id\":\"/docs/sales-69\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#client-profile\",\"content\":\"Products\"},\"716\":{\"id\":\"/docs/sales-70\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#client-profile\",\"content\":\"Products purchased by this client\"},\"717\":{\"id\":\"/docs/sales-71\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#client-profile\",\"content\":\"Vouchers\"},\"718\":{\"id\":\"/docs/sales-72\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#client-profile\",\"content\":\"Vouchers associated with this client\"},\"719\":{\"id\":\"/docs/sales-73\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#client-profile\",\"content\":\"Memberships\"},\"720\":{\"id\":\"/docs/sales-74\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#client-profile\",\"content\":\"Active and completed membership packages (shows count badge)\"},\"721\":{\"id\":\"/docs/sales-75\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#client-profile\",\"content\":\"Loyalty\"},\"722\":{\"id\":\"/docs/sales-76\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#client-profile\",\"content\":\"Loyalty programme activity\"},\"723\":{\"id\":\"/docs/sales-77\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#client-profile\",\"content\":\"**Right — Detail view**\\nClicking any item in the tabs shows the full detail on the right side. For example, clicking a sale shows the service, time, staff, subtotal, VAT, and total.\"},\"724\":{\"id\":\"/docs/sales-78\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#sale-details\",\"content\":\"Clicking a **Sale ID** or **View Details** anywhere in the Sales Hub opens the full Sale Details panel. This shows:\"},\"725\":{\"id\":\"/docs/sales-79\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#sale-details\",\"content\":\"**Status badge** (e.g., Completed)\"},\"726\":{\"id\":\"/docs/sales-80\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#sale-details\",\"content\":\"Client name and phone\"},\"727\":{\"id\":\"/docs/sales-81\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#sale-details\",\"content\":\"**VAT Invoice** number and date\"},\"728\":{\"id\":\"/docs/sales-82\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#sale-details\",\"content\":\"Services performed with time, duration, and assigned team\"},\"729\":{\"id\":\"/docs/sales-83\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#sale-details\",\"content\":\"**Staff Information** — assigned staff member and receptionist\"},\"730\":{\"id\":\"/docs/sales-84\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#sale-details\",\"content\":\"Subtotal, VAT (5%), and Total\"},\"731\":{\"id\":\"/docs/sales-85\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#sale-details\",\"content\":\"**Print icons** — print as thermal receipt or standard A4 invoice\"},\"732\":{\"id\":\"/docs/sales-86\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#sale-details\",\"content\":\"**Sale-ID** (copyable)\"},\"733\":{\"id\":\"/docs/sales-87\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#sale-details\",\"content\":\"**Void Sale** button — reverses the transaction if an error was made\"},\"734\":{\"id\":\"/docs/sales-88\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#sale-details\",\"content\":\"**Back to Appointment** button — returns to the linked appointment\"},\"735\":{\"id\":\"/docs/sales-89\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#sale-details\",\"content\":\"Voiding a sale cannot be undone. Only use this if there was a genuine error with the transaction.\"},\"736\":{\"id\":\"/docs/sales-90\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#quick-reference\",\"content\":\"Section\"},\"737\":{\"id\":\"/docs/sales-91\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#quick-reference\",\"content\":\"Best used for\"},\"738\":{\"id\":\"/docs/sales-92\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#quick-reference\",\"content\":\"Daily Sales\"},\"739\":{\"id\":\"/docs/sales-93\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#quick-reference\",\"content\":\"End-of-day reconciliation — cash, card, and tips totals\"},\"740\":{\"id\":\"/docs/sales-94\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#quick-reference\",\"content\":\"Appointments\"},\"741\":{\"id\":\"/docs/sales-95\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#quick-reference\",\"content\":\"Looking up a specific service or client visit\"},\"742\":{\"id\":\"/docs/sales-96\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#quick-reference\",\"content\":\"Sales Transactions\"},\"743\":{\"id\":\"/docs/sales-97\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#quick-reference\",\"content\":\"Full transaction log including voided sales\"},\"744\":{\"id\":\"/docs/sales-98\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#quick-reference\",\"content\":\"Payments\"},\"745\":{\"id\":\"/docs/sales-99\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#quick-reference\",\"content\":\"Collected payments only, with tips\"},\"746\":{\"id\":\"/docs/sales-100\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#quick-reference\",\"content\":\"Memberships\"},\"747\":{\"id\":\"/docs/sales-101\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#quick-reference\",\"content\":\"Session usage and package status\"},\"748\":{\"id\":\"/docs/sales-102\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#quick-reference\",\"content\":\"Vouchers\"},\"749\":{\"id\":\"/docs/sales-103\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#quick-reference\",\"content\":\"Gift card purchases and redemptions\"},\"750\":{\"id\":\"/docs/sales-104\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#quick-reference\",\"content\":\"Products\"},\"751\":{\"id\":\"/docs/sales-105\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#quick-reference\",\"content\":\"Retail sales with live stock levels\"},\"752\":{\"id\":\"/docs/sales-106\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#quick-reference\",\"content\":\"Tips\"},\"753\":{\"id\":\"/docs/sales-107\",\"page_id\":\"/docs/sales\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/sales#quick-reference\",\"content\":\"Gratuity records by staff member\"},\"754\":{\"id\":\"/docs/settings\",\"page_id\":\"/docs/settings\",\"type\":\"page\",\"content\":\"Settings\",\"breadcrumbs\":[\"Docs\"],\"tags\":[],\"url\":\"/docs/settings\"},\"755\":{\"id\":\"/docs/settings-0\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings\",\"content\":\"Configure your branches, business hours, payment methods, and permissions\"},\"756\":{\"id\":\"/docs/settings-1\",\"page_id\":\"/docs/settings\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/settings#branches\",\"content\":\"Branches\"},\"757\":{\"id\":\"/docs/settings-2\",\"page_id\":\"/docs/settings\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/settings#editing-a-branch\",\"content\":\"Editing a branch\"},\"758\":{\"id\":\"/docs/settings-3\",\"page_id\":\"/docs/settings\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/settings#calendar\",\"content\":\"Calendar\"},\"759\":{\"id\":\"/docs/settings-4\",\"page_id\":\"/docs/settings\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/settings#setting-your-hours\",\"content\":\"Setting your hours\"},\"760\":{\"id\":\"/docs/settings-5\",\"page_id\":\"/docs/settings\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/settings#payment-methods\",\"content\":\"Payment Methods\"},\"761\":{\"id\":\"/docs/settings-6\",\"page_id\":\"/docs/settings\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/settings#adding-a-payment-method\",\"content\":\"Adding a payment method\"},\"762\":{\"id\":\"/docs/settings-7\",\"page_id\":\"/docs/settings\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/settings#editing-or-deleting-a-payment-method\",\"content\":\"Editing or deleting a payment method\"},\"763\":{\"id\":\"/docs/settings-8\",\"page_id\":\"/docs/settings\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/settings#permissions\",\"content\":\"Permissions\"},\"764\":{\"id\":\"/docs/settings-9\",\"page_id\":\"/docs/settings\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/settings#allow-voucher-usage-for-tips\",\"content\":\"Allow Voucher Usage for Tips\"},\"765\":{\"id\":\"/docs/settings-10\",\"page_id\":\"/docs/settings\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/settings#accept-tips-online-only\",\"content\":\"Accept Tips Online Only\"},\"766\":{\"id\":\"/docs/settings-11\",\"page_id\":\"/docs/settings\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/settings#prevent-tips-with-manual-discount\",\"content\":\"Prevent Tips with Manual Discount\"},\"767\":{\"id\":\"/docs/settings-12\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings\",\"content\":\"Settings is where you control the core configuration of your salon. Click **Settings** in the left menu to get started. There are four sections: **Branches**, **Calendar**, **Payment Methods**, and **Permissions**.\"},\"768\":{\"id\":\"/docs/settings-13\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings\",\"content\":\"Settings is only accessible to admin users.\"},\"769\":{\"id\":\"/docs/settings-14\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#branches\",\"content\":\"**Settings → Branches**\"},\"770\":{\"id\":\"/docs/settings-15\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#branches\",\"content\":\"The Branches page shows all your salon locations. Each branch is displayed as a card showing:\"},\"771\":{\"id\":\"/docs/settings-16\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#branches\",\"content\":\"Branch photo\"},\"772\":{\"id\":\"/docs/settings-17\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#branches\",\"content\":\"Branch name and **Active** status badge\"},\"773\":{\"id\":\"/docs/settings-18\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#branches\",\"content\":\"Location ID\"},\"774\":{\"id\":\"/docs/settings-19\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#branches\",\"content\":\"Number of staff assigned\"},\"775\":{\"id\":\"/docs/settings-20\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#branches\",\"content\":\"Contact email and phone\"},\"776\":{\"id\":\"/docs/settings-21\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#branches\",\"content\":\"City and country\"},\"777\":{\"id\":\"/docs/settings-22\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#branches\",\"content\":\"TRN (Tax Registration Number)\"},\"778\":{\"id\":\"/docs/settings-23\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#branches\",\"content\":\"Date the branch was created\"},\"779\":{\"id\":\"/docs/settings-24\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#branches\",\"content\":\"A **pencil icon** to edit the branch\"},\"780\":{\"id\":\"/docs/settings-25\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#editing-a-branch\",\"content\":\"Click the **pencil icon** on any branch card to open the Edit Branch form.\"},\"781\":{\"id\":\"/docs/settings-26\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#editing-a-branch\",\"content\":\"Fields you can update:\"},\"782\":{\"id\":\"/docs/settings-27\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#editing-a-branch\",\"content\":\"**Branch Name** (required)\"},\"783\":{\"id\":\"/docs/settings-28\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#editing-a-branch\",\"content\":\"**Email**\"},\"784\":{\"id\":\"/docs/settings-29\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#editing-a-branch\",\"content\":\"**Country** (with flag selector)\"},\"785\":{\"id\":\"/docs/settings-30\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#editing-a-branch\",\"content\":\"**City**\"},\"786\":{\"id\":\"/docs/settings-31\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#editing-a-branch\",\"content\":\"**Phone** (with country code selector)\"},\"787\":{\"id\":\"/docs/settings-32\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#editing-a-branch\",\"content\":\"**TRN** — your Tax Registration Number, printed on invoices\"},\"788\":{\"id\":\"/docs/settings-33\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#editing-a-branch\",\"content\":\"**Branch Images** — upload up to 4 photos to showcase the branch (shown on the card)\"},\"789\":{\"id\":\"/docs/settings-34\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#editing-a-branch\",\"content\":\"Click **Update Branch** to save.\"},\"790\":{\"id\":\"/docs/settings-35\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#editing-a-branch\",\"content\":\"The **Location ID** is shown at the top of the form but cannot be edited — it's a system-generated identifier.\"},\"791\":{\"id\":\"/docs/settings-36\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#editing-a-branch\",\"content\":\"To add a new branch, contact NxCut support. Branch creation is managed at the account level and cannot be done directly from this page.\"},\"792\":{\"id\":\"/docs/settings-37\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#calendar\",\"content\":\"**Settings → Calendar**\"},\"793\":{\"id\":\"/docs/settings-38\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#calendar\",\"content\":\"This is where you set your salon's **Global Working Hours** — the default opening and closing times that appear on the Calendar for all staff.\"},\"794\":{\"id\":\"/docs/settings-39\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#calendar\",\"content\":\"The hours are configured per location. You'll see \\\"Configuring for: \\\\[location name]\\\" at the top so you always know which branch you're editing.\"},\"795\":{\"id\":\"/docs/settings-40\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#setting-your-hours\",\"content\":\"For each day of the week (Sunday through Saturday), you can:\"},\"796\":{\"id\":\"/docs/settings-41\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#setting-your-hours\",\"content\":\"Set a **Start Time** and **End Time**\"},\"797\":{\"id\":\"/docs/settings-42\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#setting-your-hours\",\"content\":\"Tick the **Closed** checkbox if the salon is closed that day — it will be hidden from the Calendar entirely\"},\"798\":{\"id\":\"/docs/settings-43\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#setting-your-hours\",\"content\":\"Click **Default** on any day to reset it to the default hours\"},\"799\":{\"id\":\"/docs/settings-44\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#setting-your-hours\",\"content\":\"Default hours are **08:00 AM – 11:45 PM**.\"},\"800\":{\"id\":\"/docs/settings-45\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#setting-your-hours\",\"content\":\"Once you've made your changes, click **Save Global Hours**. To reset all days back to the defaults at once, click **Reset to Default**.\"},\"801\":{\"id\":\"/docs/settings-46\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#setting-your-hours\",\"content\":\"The end time must always be later than the start time. Invalid entries will not be saved.\"},\"802\":{\"id\":\"/docs/settings-47\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#payment-methods\",\"content\":\"**Settings → Payment Methods**\"},\"803\":{\"id\":\"/docs/settings-48\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#payment-methods\",\"content\":\"This page shows all the payment options available at checkout. The default methods are: **Card**, **Cash**, **Membership**, **Online**, **Split Payment**, and **Voucher** — all active by default.\"},\"804\":{\"id\":\"/docs/settings-49\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#payment-methods\",\"content\":\"Each method is shown as a card with its name, **Active** status badge, and the date it was created.\"},\"805\":{\"id\":\"/docs/settings-50\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#adding-a-payment-method\",\"content\":\"Click **+ Add Payment Method**, enter a name, and save. The new method will immediately be available at checkout.\"},\"806\":{\"id\":\"/docs/settings-51\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#editing-or-deleting-a-payment-method\",\"content\":\"Click the &#x2A;*···** (three dots) on any card to reveal two options:\"},\"807\":{\"id\":\"/docs/settings-52\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#editing-or-deleting-a-payment-method\",\"content\":\"**Edit** — rename the method or change its status\"},\"808\":{\"id\":\"/docs/settings-53\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#editing-or-deleting-a-payment-method\",\"content\":\"**Delete** (red) — permanently remove it\"},\"809\":{\"id\":\"/docs/settings-54\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#editing-or-deleting-a-payment-method\",\"content\":\"Deleting a payment method is permanent. If you just want to stop it appearing at checkout temporarily, edit it and set it to inactive instead.\"},\"810\":{\"id\":\"/docs/settings-55\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#permissions\",\"content\":\"**Settings → Permissions**\"},\"811\":{\"id\":\"/docs/settings-56\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#permissions\",\"content\":\"Permissions let you control the rules around tips and discounts at checkout. Settings are per location — select the location you want to configure from the **Location** dropdown at the top.\"},\"812\":{\"id\":\"/docs/settings-57\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#permissions\",\"content\":\"There are three permission settings:\"},\"813\":{\"id\":\"/docs/settings-58\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#allow-voucher-usage-for-tips\",\"content\":\"**Toggle: Enable Voucher Tips**\"},\"814\":{\"id\":\"/docs/settings-59\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#allow-voucher-usage-for-tips\",\"content\":\"When turned on, clients can use a voucher as the payment method when adding a tip at checkout.\"},\"815\":{\"id\":\"/docs/settings-60\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#allow-voucher-usage-for-tips\",\"content\":\"*Off by default.*\"},\"816\":{\"id\":\"/docs/settings-61\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#accept-tips-online-only\",\"content\":\"**Toggle: Disable Tips in POS**\"},\"817\":{\"id\":\"/docs/settings-62\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#accept-tips-online-only\",\"content\":\"When turned on, the ability to add tips is completely removed from the POS checkout screen. Tips would only be accepted through online bookings.\"},\"818\":{\"id\":\"/docs/settings-63\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#accept-tips-online-only\",\"content\":\"*Off by default.*\"},\"819\":{\"id\":\"/docs/settings-64\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#prevent-tips-with-manual-discount\",\"content\":\"**Toggle: Enforce Mutual Exclusivity**\"},\"820\":{\"id\":\"/docs/settings-65\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#prevent-tips-with-manual-discount\",\"content\":\"When turned on, a staff member cannot apply both a manual discount and a tip to the same sale. If a discount is applied, the tip option is disabled — and vice versa.\"},\"821\":{\"id\":\"/docs/settings-66\",\"page_id\":\"/docs/settings\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/settings#prevent-tips-with-manual-discount\",\"content\":\"*Off by default.*\"},\"822\":{\"id\":\"/docs/team\",\"page_id\":\"/docs/team\",\"type\":\"page\",\"content\":\"Team Management\",\"breadcrumbs\":[\"Docs\"],\"tags\":[],\"url\":\"/docs/team\"},\"823\":{\"id\":\"/docs/team-0\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team\",\"content\":\"Add staff, set their schedules, and control what they can access\"},\"824\":{\"id\":\"/docs/team-1\",\"page_id\":\"/docs/team\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/team#team-members\",\"content\":\"Team Members\"},\"825\":{\"id\":\"/docs/team-2\",\"page_id\":\"/docs/team\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/team#adding-a-team-member\",\"content\":\"Adding a team member\"},\"826\":{\"id\":\"/docs/team-3\",\"page_id\":\"/docs/team\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/team#editing-a-team-member\",\"content\":\"Editing a team member\"},\"827\":{\"id\":\"/docs/team-4\",\"page_id\":\"/docs/team\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/team#setting-working-hours-edit-shift\",\"content\":\"Setting working hours (Edit Shift)\"},\"828\":{\"id\":\"/docs/team-5\",\"page_id\":\"/docs/team\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/team#authenticated-users\",\"content\":\"Authenticated Users\"},\"829\":{\"id\":\"/docs/team-6\",\"page_id\":\"/docs/team\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/team#adding-a-login-account-auth-user\",\"content\":\"Adding a login account (Auth User)\"},\"830\":{\"id\":\"/docs/team-7\",\"page_id\":\"/docs/team\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/team#archiving-a-team-member\",\"content\":\"Archiving a team member\"},\"831\":{\"id\":\"/docs/team-8\",\"page_id\":\"/docs/team\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/team#quick-reference\",\"content\":\"Quick reference\"},\"832\":{\"id\":\"/docs/team-9\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team\",\"content\":\"The Team Management page is where you manage everyone who works at your salon — their profiles, working hours, service permissions, and login accounts.\"},\"833\":{\"id\":\"/docs/team-10\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team\",\"content\":\"Click **Team** in the left menu to get started. The page is divided into two sections: **Team Members** and **Authenticated Users**.\"},\"834\":{\"id\":\"/docs/team-11\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#team-members\",\"content\":\"Team Members are the staff profiles that appear on the Calendar. Each card shows the staff member's photo (or initials if no photo is set), their email, and phone number.\"},\"835\":{\"id\":\"/docs/team-12\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#team-members\",\"content\":\"Each card has three action buttons:\"},\"836\":{\"id\":\"/docs/team-13\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#team-members\",\"content\":\"**Edit Shift** — set their weekly working hours\"},\"837\":{\"id\":\"/docs/team-14\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#team-members\",\"content\":\"**Edit** — update their profile details\"},\"838\":{\"id\":\"/docs/team-15\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#team-members\",\"content\":\"**Delete** (red trash icon) — remove them permanently\"},\"839\":{\"id\":\"/docs/team-16\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#team-members\",\"content\":\"To view archived staff, toggle **Show archived team members only** in the top right corner.\"},\"840\":{\"id\":\"/docs/team-17\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#adding-a-team-member\",\"content\":\"Click **+ Add → Add Team Member**. A form will pop up.\"},\"841\":{\"id\":\"/docs/team-18\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#adding-a-team-member\",\"content\":\"Click the &#x2A;*+** circle at the top to upload a profile photo (JPEG or PNG, under 2 MB). This is optional but recommended — it helps identify staff on the Calendar.\"},\"842\":{\"id\":\"/docs/team-19\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#adding-a-team-member\",\"content\":\"Enter their **First Name** (required) and **Last Name**.\"},\"843\":{\"id\":\"/docs/team-20\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#adding-a-team-member\",\"content\":\"Set a **Calendar Color** — this is the color used for their column on the Calendar. Each staff member should have a distinct color to make them easy to tell apart.\"},\"844\":{\"id\":\"/docs/team-21\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#adding-a-team-member\",\"content\":\"Optionally enter a **Team Member ID** — useful if your business uses internal staff ID numbers.\"},\"845\":{\"id\":\"/docs/team-22\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#adding-a-team-member\",\"content\":\"Set **Category Permissions** — toggle on the service categories this staff member is allowed to perform (e.g., Hair, Nails, Facial). All categories are enabled by default. Staff will only appear as a booking option for the categories you enable.\"},\"846\":{\"id\":\"/docs/team-23\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#adding-a-team-member\",\"content\":\"Toggle **Visible to Clients** on if this staff member should appear in client-facing booking. This is on by default.\"},\"847\":{\"id\":\"/docs/team-24\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#adding-a-team-member\",\"content\":\"Toggle **Admin User** on if they need full access to the system (Reports, Settings, Commission, Dashboard). Off by default.\"},\"848\":{\"id\":\"/docs/team-25\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#adding-a-team-member\",\"content\":\"Select a **Location** (required).\"},\"849\":{\"id\":\"/docs/team-26\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#adding-a-team-member\",\"content\":\"Click **Add Team Member**.\"},\"850\":{\"id\":\"/docs/team-27\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#editing-a-team-member\",\"content\":\"Click **Edit** on any team member card to update their photo, name, calendar color, category permissions, admin status, or location.\"},\"851\":{\"id\":\"/docs/team-28\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#editing-a-team-member\",\"content\":\"You cannot remove admin access from the last remaining admin. Make sure at least one other admin exists before making that change.\"},\"852\":{\"id\":\"/docs/team-29\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#setting-working-hours-edit-shift\",\"content\":\"Each staff member can have their own weekly schedule so the Calendar only shows them as available when they're actually working.\"},\"853\":{\"id\":\"/docs/team-30\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#setting-working-hours-edit-shift\",\"content\":\"Click **Edit Shift** on the team member's card.\"},\"854\":{\"id\":\"/docs/team-31\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#setting-working-hours-edit-shift\",\"content\":\"For each day of the week, set their **start** and **finish time**.\"},\"855\":{\"id\":\"/docs/team-32\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#setting-working-hours-edit-shift\",\"content\":\"Mark any day as **Off** if they don't work that day.\"},\"856\":{\"id\":\"/docs/team-33\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#setting-working-hours-edit-shift\",\"content\":\"Click **Save**.\"},\"857\":{\"id\":\"/docs/team-34\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#authenticated-users\",\"content\":\"The **Authenticated Users** section sits below the team member grid and shows all staff login accounts. These cards have an **orange border** to distinguish them from team member profiles.\"},\"858\":{\"id\":\"/docs/team-35\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#authenticated-users\",\"content\":\"Each card shows the user's name, their **Auth User** label, email address, and Location ID.\"},\"859\":{\"id\":\"/docs/team-36\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#authenticated-users\",\"content\":\"A team member profile and a login account are two separate things. A team member profile controls how someone appears on the Calendar. A login account controls how they log in to NxCut. Most staff will need both.\"},\"860\":{\"id\":\"/docs/team-37\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#adding-a-login-account-auth-user\",\"content\":\"Click **+ Add → Add Auth User**. A form will pop up.\"},\"861\":{\"id\":\"/docs/team-38\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#adding-a-login-account-auth-user\",\"content\":\"Enter their **Email** (required) — this will be their username when logging in.\"},\"862\":{\"id\":\"/docs/team-39\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#adding-a-login-account-auth-user\",\"content\":\"Set a **Password** (required).\"},\"863\":{\"id\":\"/docs/team-40\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#adding-a-login-account-auth-user\",\"content\":\"Optionally enter a **Display Name** and **Phone Number**.\"},\"864\":{\"id\":\"/docs/team-41\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#adding-a-login-account-auth-user\",\"content\":\"Toggle **Admin User** on if they should have full system access.\"},\"865\":{\"id\":\"/docs/team-42\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#adding-a-login-account-auth-user\",\"content\":\"Select a **Location** (required).\"},\"866\":{\"id\":\"/docs/team-43\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#adding-a-login-account-auth-user\",\"content\":\"Click **Create User**. The account is active immediately.\"},\"867\":{\"id\":\"/docs/team-44\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#archiving-a-team-member\",\"content\":\"If someone leaves but you want to keep their history in the system, archive them instead of deleting.\"},\"868\":{\"id\":\"/docs/team-45\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#archiving-a-team-member\",\"content\":\"Open their profile and choose **Archive**.\"},\"869\":{\"id\":\"/docs/team-46\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#archiving-a-team-member\",\"content\":\"Archived members are hidden from the default view.\"},\"870\":{\"id\":\"/docs/team-47\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#archiving-a-team-member\",\"content\":\"Toggle **Show archived team members only** at the top of the page to find them again.\"},\"871\":{\"id\":\"/docs/team-48\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#quick-reference\",\"content\":\"Feature\"},\"872\":{\"id\":\"/docs/team-49\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#quick-reference\",\"content\":\"Details\"},\"873\":{\"id\":\"/docs/team-50\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#quick-reference\",\"content\":\"Profile photo\"},\"874\":{\"id\":\"/docs/team-51\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#quick-reference\",\"content\":\"JPEG or PNG, max 2 MB\"},\"875\":{\"id\":\"/docs/team-52\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#quick-reference\",\"content\":\"Calendar color\"},\"876\":{\"id\":\"/docs/team-53\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#quick-reference\",\"content\":\"Makes each staff member's column easy to identify\"},\"877\":{\"id\":\"/docs/team-54\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#quick-reference\",\"content\":\"Team Member ID\"},\"878\":{\"id\":\"/docs/team-55\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#quick-reference\",\"content\":\"Optional internal staff ID number\"},\"879\":{\"id\":\"/docs/team-56\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#quick-reference\",\"content\":\"Category permissions\"},\"880\":{\"id\":\"/docs/team-57\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#quick-reference\",\"content\":\"Per-category toggles — controls which services they can be booked for\"},\"881\":{\"id\":\"/docs/team-58\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#quick-reference\",\"content\":\"Working hours\"},\"882\":{\"id\":\"/docs/team-59\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#quick-reference\",\"content\":\"Set per staff member, per day of the week\"},\"883\":{\"id\":\"/docs/team-60\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#quick-reference\",\"content\":\"Auth users\"},\"884\":{\"id\":\"/docs/team-61\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#quick-reference\",\"content\":\"Separate login accounts shown with an orange border\"},\"885\":{\"id\":\"/docs/team-62\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#quick-reference\",\"content\":\"Admin access\"},\"886\":{\"id\":\"/docs/team-63\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#quick-reference\",\"content\":\"Grants full access to Reports, Settings, Commission, and Dashboard\"},\"887\":{\"id\":\"/docs/team-64\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#quick-reference\",\"content\":\"Visible to clients\"},\"888\":{\"id\":\"/docs/team-65\",\"page_id\":\"/docs/team\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/team#quick-reference\",\"content\":\"Controls whether they appear in client-facing booking\"},\"889\":{\"id\":\"/docs/test\",\"page_id\":\"/docs/test\",\"type\":\"page\",\"content\":\"Components\",\"tags\":[],\"url\":\"/docs/test\"},\"890\":{\"id\":\"/docs/test-0\",\"page_id\":\"/docs/test\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/test\",\"content\":\"Components\"},\"891\":{\"id\":\"/docs/test-1\",\"page_id\":\"/docs/test\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/test#code-block\",\"content\":\"Code Block\"},\"892\":{\"id\":\"/docs/test-2\",\"page_id\":\"/docs/test\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/test#cards\",\"content\":\"Cards\"},\"893\":{\"id\":\"/docs/test-3\",\"page_id\":\"/docs/test\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/test#cards\",\"content\":\"<Card title=\\\"Learn more about Next.js\\\" href=\\\"https://nextjs.org/docs\\\" />\"},\"894\":{\"id\":\"/docs/test-4\",\"page_id\":\"/docs/test\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/test#cards\",\"content\":\"<Card title=\\\"Learn more about Fumadocs\\\" href=\\\"https://fumadocs.dev\\\" />\"},\"895\":{\"id\":\"/docs/website\",\"page_id\":\"/docs/website\",\"type\":\"page\",\"content\":\"Website & Booking Module\",\"breadcrumbs\":[\"Docs\"],\"tags\":[],\"url\":\"/docs/website\"},\"896\":{\"id\":\"/docs/website-0\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website\",\"content\":\"Manage your public booking Module and salon website profile\"},\"897\":{\"id\":\"/docs/website-1\",\"page_id\":\"/docs/website\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/website#edit-your-profile\",\"content\":\"Edit your profile\"},\"898\":{\"id\":\"/docs/website-2\",\"page_id\":\"/docs/website\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/website#website-details\",\"content\":\"Website Details\"},\"899\":{\"id\":\"/docs/website-3\",\"page_id\":\"/docs/website\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/website#contact-us\",\"content\":\"Contact Us\"},\"900\":{\"id\":\"/docs/website-4\",\"page_id\":\"/docs/website\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/website#how-the-client-booking-flow-works\",\"content\":\"How the client booking flow works\"},\"901\":{\"id\":\"/docs/website-5\",\"page_id\":\"/docs/website\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/website#step-1--select-a-location\",\"content\":\"Step 1 — Select a location\"},\"902\":{\"id\":\"/docs/website-6\",\"page_id\":\"/docs/website\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/website#step-2--browse-the-price-menu\",\"content\":\"Step 2 — Browse the price menu\"},\"903\":{\"id\":\"/docs/website-7\",\"page_id\":\"/docs/website\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/website#step-3--pick-a-professional\",\"content\":\"Step 3 — Pick a professional\"},\"904\":{\"id\":\"/docs/website-8\",\"page_id\":\"/docs/website\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/website#step-4--choose-a-date-and-time\",\"content\":\"Step 4 — Choose a date and time\"},\"905\":{\"id\":\"/docs/website-9\",\"page_id\":\"/docs/website\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/website#step-5--enter-contact-details\",\"content\":\"Step 5 — Enter contact details\"},\"906\":{\"id\":\"/docs/website-10\",\"page_id\":\"/docs/website\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/website#step-6--appointment-confirmed\",\"content\":\"Step 6 — Appointment confirmed\"},\"907\":{\"id\":\"/docs/website-11\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website\",\"content\":\"NxCut automatically creates a public booking Module for your salon. Clients can visit it to browse your services, pick a staff member, choose a time, and book an appointment — without you needing to do anything to set it up.\"},\"908\":{\"id\":\"/docs/website-12\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website\",\"content\":\"Click the **globe icon** in the left menu to manage your website settings.\"},\"909\":{\"id\":\"/docs/website-13\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website\",\"content\":\"The Website section is only accessible to admin users.\"},\"910\":{\"id\":\"/docs/website-14\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website\",\"content\":\"At the top right of the page you'll find two quick-access buttons:\"},\"911\":{\"id\":\"/docs/website-15\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website\",\"content\":\"**Booking Page** — opens your live client booking page in a new tab\"},\"912\":{\"id\":\"/docs/website-16\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website\",\"content\":\"**My Website** — opens your full salon website\"},\"913\":{\"id\":\"/docs/website-17\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#edit-your-profile\",\"content\":\"The first section lets you update your salon's basic public information.\"},\"914\":{\"id\":\"/docs/website-18\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#edit-your-profile\",\"content\":\"Field\"},\"915\":{\"id\":\"/docs/website-19\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#edit-your-profile\",\"content\":\"What it's for\"},\"916\":{\"id\":\"/docs/website-20\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#edit-your-profile\",\"content\":\"Salon Name\"},\"917\":{\"id\":\"/docs/website-21\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#edit-your-profile\",\"content\":\"The name displayed on your booking page\"},\"918\":{\"id\":\"/docs/website-22\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#edit-your-profile\",\"content\":\"Mobile Number\"},\"919\":{\"id\":\"/docs/website-23\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#edit-your-profile\",\"content\":\"Your salon's contact number\"},\"920\":{\"id\":\"/docs/website-24\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#edit-your-profile\",\"content\":\"Email Address\"},\"921\":{\"id\":\"/docs/website-25\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#edit-your-profile\",\"content\":\"Your contact email\"},\"922\":{\"id\":\"/docs/website-26\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#edit-your-profile\",\"content\":\"Owner Name\"},\"923\":{\"id\":\"/docs/website-27\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#edit-your-profile\",\"content\":\"The name of the salon owner\"},\"924\":{\"id\":\"/docs/website-28\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#edit-your-profile\",\"content\":\"Website\"},\"925\":{\"id\":\"/docs/website-29\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#edit-your-profile\",\"content\":\"Your auto-generated booking URL (read-only)\"},\"926\":{\"id\":\"/docs/website-30\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#edit-your-profile\",\"content\":\"Click **Save Changes** when done.\"},\"927\":{\"id\":\"/docs/website-31\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#website-details\",\"content\":\"Customise how your booking page looks to clients.\"},\"928\":{\"id\":\"/docs/website-32\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#website-details\",\"content\":\"Field\"},\"929\":{\"id\":\"/docs/website-33\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#website-details\",\"content\":\"What it's for\"},\"930\":{\"id\":\"/docs/website-34\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#website-details\",\"content\":\"Logo Text\"},\"931\":{\"id\":\"/docs/website-35\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#website-details\",\"content\":\"The text displayed as your logo\"},\"932\":{\"id\":\"/docs/website-36\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#website-details\",\"content\":\"Website Title\"},\"933\":{\"id\":\"/docs/website-37\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#website-details\",\"content\":\"The page title shown in the browser tab\"},\"934\":{\"id\":\"/docs/website-38\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#website-details\",\"content\":\"Landing Page Image\"},\"935\":{\"id\":\"/docs/website-39\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#website-details\",\"content\":\"The hero image at the top of your booking page (PNG, JPG, GIF or WebP, max 5MB)\"},\"936\":{\"id\":\"/docs/website-40\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#website-details\",\"content\":\"Click **Upload Image** to add or replace the landing page photo, then click **Save Changes**.\"},\"937\":{\"id\":\"/docs/website-41\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#contact-us\",\"content\":\"This section shows the contact details displayed to clients on your booking page — your email address and WhatsApp number. These are pulled from your profile automatically.\"},\"938\":{\"id\":\"/docs/website-42\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#how-the-client-booking-flow-works\",\"content\":\"When a client visits your booking page, they go through a simple step-by-step process:\"},\"939\":{\"id\":\"/docs/website-43\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#step-1--select-a-location\",\"content\":\"The client picks which branch they want to visit. If you only have one location, this step is skipped automatically.\"},\"940\":{\"id\":\"/docs/website-44\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#step-2--browse-the-price-menu\",\"content\":\"Services are grouped by category (Facial, Hair, Nails, etc.). Prices include 5% VAT. The client taps a category to see the individual services and their prices, then selects the one they want.\"},\"941\":{\"id\":\"/docs/website-45\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#step-3--pick-a-professional\",\"content\":\"The client chooses which staff member they'd like. They can pick a specific person or select **Any Agent** to be assigned to whoever is available.\"},\"942\":{\"id\":\"/docs/website-46\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#step-4--choose-a-date-and-time\",\"content\":\"A calendar shows the current month. Days with available slots are marked with a **green underline**. The client clicks a date to see the available time slots for that day, then taps a green slot to reserve it.\"},\"943\":{\"id\":\"/docs/website-47\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#step-4--choose-a-date-and-time\",\"content\":\"A **Summary*&#x2A; panel on the right shows the selected service, agent, and total price. The client can also click **+ Add More** to add additional services to the same booking.\"},\"944\":{\"id\":\"/docs/website-48\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#step-5--enter-contact-details\",\"content\":\"The client fills in their information:\"},\"945\":{\"id\":\"/docs/website-49\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#step-5--enter-contact-details\",\"content\":\"**New Client** — enters their details for the first time\"},\"946\":{\"id\":\"/docs/website-50\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#step-5--enter-contact-details\",\"content\":\"**Existing Client** — enters their registered phone number to pull up their profile\"},\"947\":{\"id\":\"/docs/website-51\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#step-5--enter-contact-details\",\"content\":\"They can also add any **special requests or notes** in the Additional Comments field.\"},\"948\":{\"id\":\"/docs/website-52\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#step-6--appointment-confirmed\",\"content\":\"After submitting, a confirmation screen appears showing:\"},\"949\":{\"id\":\"/docs/website-53\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#step-6--appointment-confirmed\",\"content\":\"A green **Appointment Confirmed** message\"},\"950\":{\"id\":\"/docs/website-54\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#step-6--appointment-confirmed\",\"content\":\"A unique &#x2A;*ORDER #** for reference\"},\"951\":{\"id\":\"/docs/website-55\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#step-6--appointment-confirmed\",\"content\":\"The date, time, service, agent, and location\"},\"952\":{\"id\":\"/docs/website-56\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#step-6--appointment-confirmed\",\"content\":\"**Add to Calendar** and **Print** buttons\"},\"953\":{\"id\":\"/docs/website-57\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#step-6--appointment-confirmed\",\"content\":\"A full **Cost Breakdown** showing the service price, any credits applied, and the balance due\"},\"954\":{\"id\":\"/docs/website-58\",\"page_id\":\"/docs/website\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/website#step-6--appointment-confirmed\",\"content\":\"The appointment is instantly added to your Calendar in NxCut and visible to the assigned staff member.\"}},\"count\":954},\"sorting\"