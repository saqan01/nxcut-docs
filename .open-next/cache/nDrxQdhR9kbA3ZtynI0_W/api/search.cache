24\":3,\"925\":3,\"926\":3,\"927\":3,\"928\":3,\"929\":3,\"930\":3,\"931\":3,\"932\":3,\"933\":3,\"934\":3,\"935\":3,\"936\":3,\"937\":3,\"938\":3,\"939\":3,\"940\":3,\"941\":3,\"942\":3,\"943\":3,\"944\":3,\"945\":3,\"946\":3,\"947\":3,\"948\":3,\"949\":3,\"950\":3,\"951\":3,\"952\":3,\"953\":3,\"954\":3}}},\"docs\":{\"docs\":{\"1\":{\"id\":\"/docs/calendar\",\"page_id\":\"/docs/calendar\",\"type\":\"page\",\"content\":\"Calendar & Bookings\",\"breadcrumbs\":[\"Docs\"],\"tags\":[],\"url\":\"/docs/calendar\"},\"2\":{\"id\":\"/docs/calendar-0\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar\",\"content\":\"Book, view, and manage all your salon appointments in one place\"},\"3\":{\"id\":\"/docs/calendar-1\",\"page_id\":\"/docs/calendar\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/calendar#how-the-calendar-is-laid-out\",\"content\":\"How the Calendar is laid out\"},\"4\":{\"id\":\"/docs/calendar-2\",\"page_id\":\"/docs/calendar\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/calendar#booking-a-new-appointment\",\"content\":\"Booking a new appointment\"},\"5\":{\"id\":\"/docs/calendar-3\",\"page_id\":\"/docs/calendar\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/calendar#step-1--select-a-client\",\"content\":\"Step 1 — Select a client\"},\"6\":{\"id\":\"/docs/calendar-4\",\"page_id\":\"/docs/calendar\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/calendar#step-2--add-services\",\"content\":\"Step 2 — Add services\"},\"7\":{\"id\":\"/docs/calendar-5\",\"page_id\":\"/docs/calendar\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/calendar#step-3--save\",\"content\":\"Step 3 — Save\"},\"8\":{\"id\":\"/docs/calendar-6\",\"page_id\":\"/docs/calendar\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/calendar#appointment-card-hover\",\"content\":\"Appointment card hover\"},\"9\":{\"id\":\"/docs/calendar-7\",\"page_id\":\"/docs/calendar\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/calendar#editing-an-appointment\",\"content\":\"Editing an appointment\"},\"10\":{\"id\":\"/docs/calendar-8\",\"page_id\":\"/docs/calendar\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/calendar#appointment-statuses\",\"content\":\"Appointment statuses\"},\"11\":{\"id\":\"/docs/calendar-9\",\"page_id\":\"/docs/calendar\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/calendar#blocking-time-off\",\"content\":\"Blocking time off\"},\"12\":{\"id\":\"/docs/calendar-10\",\"page_id\":\"/docs/calendar\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/calendar#going-to-checkout-from-the-calendar\",\"content\":\"Going to checkout from the calendar\"},\"13\":{\"id\":\"/docs/calendar-11\",\"page_id\":\"/docs/calendar\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/calendar#quick-reference\",\"content\":\"Quick reference\"},\"14\":{\"id\":\"/docs/calendar-12\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar\",\"content\":\"The Calendar is where all your appointments live. It shows your team's full schedule side by side — one column per staff member — so you can see everyone's day at a glance and book new appointments in seconds.\"},\"15\":{\"id\":\"/docs/calendar-13\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#how-the-calendar-is-laid-out\",\"content\":\"When you open the Calendar you'll see:\"},\"16\":{\"id\":\"/docs/calendar-14\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#how-the-calendar-is-laid-out\",\"content\":\"**A column for each staff member** — each person has their own lane with their profile photo and name at the top\"},\"17\":{\"id\":\"/docs/calendar-15\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#how-the-calendar-is-laid-out\",\"content\":\"**Time slots running down the page** — the interval (15, 30, or 45 min) is set in Settings → Calendar\"},\"18\":{\"id\":\"/docs/calendar-16\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#how-the-calendar-is-laid-out\",\"content\":\"**A red line showing the current time** — so you always know where you are in the day\"},\"19\":{\"id\":\"/docs/calendar-17\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#how-the-calendar-is-laid-out\",\"content\":\"**Appointment cards** — each card shows the client name, service, and time range\"},\"20\":{\"id\":\"/docs/calendar-18\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#how-the-calendar-is-laid-out\",\"content\":\"**Navigation bar at the top** — use **Today*&#x2A;, &#x2A;*\\\\<*&#x2A;, and &#x2A;*>** to move between days, or click the date to jump to a specific day\"},\"21\":{\"id\":\"/docs/calendar-19\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#how-the-calendar-is-laid-out\",\"content\":\"The **+ Add** button in the top right corner is for selling products, memberships, or vouchers directly — it opens a cart where you select the items and a client. It is **not** for creating appointments. To book an appointment, click directly on an empty time slot in a staff column.\"},\"22\":{\"id\":\"/docs/calendar-20\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#booking-a-new-appointment\",\"content\":\"To create an appointment, click on any **empty time slot** in a staff member's column. A booking panel will slide open on the right side of the screen.\"},\"23\":{\"id\":\"/docs/calendar-21\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#step-1--select-a-client\",\"content\":\"The left side of the panel shows your client list. You can:\"},\"24\":{\"id\":\"/docs/calendar-22\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#step-1--select-a-client\",\"content\":\"**Search** by name or phone number\"},\"25\":{\"id\":\"/docs/calendar-23\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#step-1--select-a-client\",\"content\":\"Select an **existing client** from the list\"},\"26\":{\"id\":\"/docs/calendar-24\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#step-1--select-a-client\",\"content\":\"Choose **Walk-In Customer** if the client isn't registered\"},\"27\":{\"id\":\"/docs/calendar-25\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#step-1--select-a-client\",\"content\":\"Click **Add new client** to create a new profile on the spot\"},\"28\":{\"id\":\"/docs/calendar-26\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#step-1--select-a-client\",\"content\":\"You don't need to pre-register a client. Walk-In Customer works perfectly for first-time or unregistered visitors.\"},\"29\":{\"id\":\"/docs/calendar-27\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#step-1--select-a-client\",\"content\":\"Once you select a client, their name, phone, and email will be confirmed on screen. You can click **Change Client** if you need to swap to someone else, or **View \\\\[Client]'s Profile** to open their full history.\"},\"30\":{\"id\":\"/docs/calendar-28\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#step-2--add-services\",\"content\":\"On the right side of the panel, click **+ Add service**. A service picker will open showing all your available services with their price and duration.\"},\"31\":{\"id\":\"/docs/calendar-29\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#step-2--add-services\",\"content\":\"Tick the **checkbox** next to any service you want to add\"},\"32\":{\"id\":\"/docs/calendar-30\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#step-2--add-services\",\"content\":\"You can select multiple services at once\"},\"33\":{\"id\":\"/docs/calendar-31\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#step-2--add-services\",\"content\":\"Click **Done** when you're finished\"},\"34\":{\"id\":\"/docs/calendar-32\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#step-2--add-services\",\"content\":\"The selected services appear in the **Appointment** panel showing the time, duration, assigned team, and price. The total updates automatically at the bottom.\"},\"35\":{\"id\":\"/docs/calendar-33\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#step-3--save\",\"content\":\"Click **Save*&#x2A;. The appointment is created instantly and appears as a card on the calendar. A green &#x2A;*\\\"Appointment created successfully\\\"** notification will confirm it.\"},\"36\":{\"id\":\"/docs/calendar-34\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#appointment-card-hover\",\"content\":\"Hover over any appointment card on the calendar to see a quick summary popup showing:\"},\"37\":{\"id\":\"/docs/calendar-35\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#appointment-card-hover\",\"content\":\"The time range (e.g., 14:30 – 15:30)\"},\"38\":{\"id\":\"/docs/calendar-36\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#appointment-card-hover\",\"content\":\"The current status badge (e.g., **Scheduled**)\"},\"39\":{\"id\":\"/docs/calendar-37\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#appointment-card-hover\",\"content\":\"The client's name and phone number\"},\"40\":{\"id\":\"/docs/calendar-38\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#appointment-card-hover\",\"content\":\"The service name, team, duration, and price\"},\"41\":{\"id\":\"/docs/calendar-39\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#editing-an-appointment\",\"content\":\"Click on an existing appointment card to open the **Edit Appointment** panel. It works the same as the booking panel — you can change the client, add or remove services, or update the time or Status.\"},\"42\":{\"id\":\"/docs/calendar-40\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#editing-an-appointment\",\"content\":\"At the top of the edit panel you'll see status action buttons:\"},\"43\":{\"id\":\"/docs/calendar-41\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#editing-an-appointment\",\"content\":\"Button\"},\"44\":{\"id\":\"/docs/calendar-42\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#editing-an-appointment\",\"content\":\"What it does\"},\"45\":{\"id\":\"/docs/calendar-43\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#editing-an-appointment\",\"content\":\"**Arrived**\"},\"46\":{\"id\":\"/docs/calendar-44\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#editing-an-appointment\",\"content\":\"Marks the client as checked in and present\"},\"47\":{\"id\":\"/docs/calendar-45\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#editing-an-appointment\",\"content\":\"**Start**\"},\"48\":{\"id\":\"/docs/calendar-46\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#editing-an-appointment\",\"content\":\"Marks the service as actively in progress\"},\"49\":{\"id\":\"/docs/calendar-47\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#editing-an-appointment\",\"content\":\"**No Show**\"},\"50\":{\"id\":\"/docs/calendar-48\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#editing-an-appointment\",\"content\":\"Records that the client didn't show up\"},\"51\":{\"id\":\"/docs/calendar-49\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#editing-an-appointment\",\"content\":\"**Cancel**\"},\"52\":{\"id\":\"/docs/calendar-50\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#editing-an-appointment\",\"content\":\"Cancels the appointment\"},\"53\":{\"id\":\"/docs/calendar-51\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#editing-an-appointment\",\"content\":\"The status is reflected both on the appointment card and in the hover popup.\"},\"54\":{\"id\":\"/docs/calendar-52\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#editing-an-appointment\",\"content\":\"At the bottom of the panel you'll see two buttons:\"},\"55\":{\"id\":\"/docs/calendar-53\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#editing-an-appointment\",\"content\":\"**Save** — saves any changes you made\"},\"56\":{\"id\":\"/docs/calendar-54\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#editing-an-appointment\",\"content\":\"**Checkout** — moves the appointment to the payment screen to collect payment\"},\"57\":{\"id\":\"/docs/calendar-55\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#appointment-statuses\",\"content\":\"Status\"},\"58\":{\"id\":\"/docs/calendar-56\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#appointment-statuses\",\"content\":\"What it means\"},\"59\":{\"id\":\"/docs/calendar-57\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#appointment-statuses\",\"content\":\"Scheduled\"},\"60\":{\"id\":\"/docs/calendar-58\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#appointment-statuses\",\"content\":\"The appointment is booked and upcoming\"},\"61\":{\"id\":\"/docs/calendar-59\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#appointment-statuses\",\"content\":\"Arrived\"},\"62\":{\"id\":\"/docs/calendar-60\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#appointment-statuses\",\"content\":\"The client has arrived at the salon\"},\"63\":{\"id\":\"/docs/calendar-61\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#appointment-statuses\",\"content\":\"Start\"},\"64\":{\"id\":\"/docs/calendar-62\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#appointment-statuses\",\"content\":\"The service is currently in progress\"},\"65\":{\"id\":\"/docs/calendar-63\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#appointment-statuses\",\"content\":\"No Show\"},\"66\":{\"id\":\"/docs/calendar-64\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#appointment-statuses\",\"content\":\"The client didn't show up\"},\"67\":{\"id\":\"/docs/calendar-65\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#appointment-statuses\",\"content\":\"Cancelled\"},\"68\":{\"id\":\"/docs/calendar-66\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#appointment-statuses\",\"content\":\"The appointment was cancelled\"},\"69\":{\"id\":\"/docs/calendar-67\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#blocking-time-off\",\"content\":\"Need to mark a staff member as unavailable for a break, training, or any other reason? You can block out time without creating a real appointment.\"},\"70\":{\"id\":\"/docs/calendar-68\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#blocking-time-off\",\"content\":\"Click on an empty time slot in a staff member's column and select **Block Time**.\"},\"71\":{\"id\":\"/docs/calendar-69\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#blocking-time-off\",\"content\":\"Set the start time, end time, and an optional note so the team knows why the slot is blocked.\"},\"72\":{\"id\":\"/docs/calendar-70\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#blocking-time-off\",\"content\":\"Click **Save**. The blocked slot will appear as a distinct card on the calendar.\"},\"73\":{\"id\":\"/docs/calendar-71\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#going-to-checkout-from-the-calendar\",\"content\":\"Once a client's appointment is done, you can take payment directly from the calendar.\"},\"74\":{\"id\":\"/docs/calendar-72\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#going-to-checkout-from-the-calendar\",\"content\":\"Click on the appointment card to open the Edit Appointment panel.\"},\"75\":{\"id\":\"/docs/calendar-73\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#going-to-checkout-from-the-calendar\",\"content\":\"Click **Checkout** at the bottom of the panel.\"},\"76\":{\"id\":\"/docs/calendar-74\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#going-to-checkout-from-the-calendar\",\"content\":\"The payment screen opens with the services already loaded. Follow the Checkout steps to apply discounts, add a tip, and collect payment.\"},\"77\":{\"id\":\"/docs/calendar-75\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#quick-reference\",\"content\":\"Feature\"},\"78\":{\"id\":\"/docs/calendar-76\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#quick-reference\",\"content\":\"How it works\"},\"79\":{\"id\":\"/docs/calendar-77\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#quick-reference\",\"content\":\"Staff columns\"},\"80\":{\"id\":\"/docs/calendar-78\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#quick-reference\",\"content\":\"One column per team member with their photo\"},\"81\":{\"id\":\"/docs/calendar-79\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#quick-reference\",\"content\":\"Date navigation\"},\"82\":{\"id\":\"/docs/calendar-80\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#quick-reference\",\"content\":\"Use Today, \\\\<, and > buttons to change the day\"},\"83\":{\"id\":\"/docs/calendar-81\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#quick-reference\",\"content\":\"Walk-in booking\"},\"84\":{\"id\":\"/docs/calendar-82\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#quick-reference\",\"content\":\"Select \\\"Walk-In Customer\\\" — no profile needed\"},\"85\":{\"id\":\"/docs/calendar-83\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#quick-reference\",\"content\":\"Multiple services\"},\"86\":{\"id\":\"/docs/calendar-84\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#quick-reference\",\"content\":\"Tick as many services as needed in the service picker\"},\"87\":{\"id\":\"/docs/calendar-85\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#quick-reference\",\"content\":\"Appointment statuses\"},\"88\":{\"id\":\"/docs/calendar-86\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#quick-reference\",\"content\":\"Arrived, Start, No Show, Cancel — updated from the edit panel\"},\"89\":{\"id\":\"/docs/calendar-87\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#quick-reference\",\"content\":\"Hover card\"},\"90\":{\"id\":\"/docs/calendar-88\",\"page_id\":\"/docs/calendar\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/calendar#quick-reference\",\"content\":\"Hover an appointment to see a quick summary without opening it\"},\"91\":{\"id\":\"/docs/catalog\",\"page_id\":\"/docs/catalog\",\"type\":\"page\",\"content\":\"Catalog & Inventory\",\"breadcrumbs\":[\"Docs\"],\"tags\":[],\"url\":\"/docs/catalog\"},\"92\":{\"id\":\"/docs/catalog-0\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog\",\"content\":\"Set up your services, products, memberships, vouchers, and manage stock\"},\"93\":{\"id\":\"/docs/catalog-1\",\"page_id\":\"/docs/catalog\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/catalog#services\",\"content\":\"Services\"},\"94\":{\"id\":\"/docs/catalog-2\",\"page_id\":\"/docs/catalog\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/catalog#adding-a-service\",\"content\":\"Adding a service\"},\"95\":{\"id\":\"/docs/catalog-3\",\"page_id\":\"/docs/catalog\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/catalog#editing-or-removing-a-service\",\"content\":\"Editing or removing a service\"},\"96\":{\"id\":\"/docs/catalog-4\",\"page_id\":\"/docs/catalog\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/catalog#products\",\"content\":\"Products\"},\"97\":{\"id\":\"/docs/catalog-5\",\"page_id\":\"/docs/catalog\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/catalog#adding-a-product\",\"content\":\"Adding a product\"},\"98\":{\"id\":\"/docs/catalog-6\",\"page_id\":\"/docs/catalog\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/catalog#memberships\",\"content\":\"Memberships\"},\"99\":{\"id\":\"/docs/catalog-7\",\"page_id\":\"/docs/catalog\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/catalog#creating-a-membership\",\"content\":\"Creating a membership\"},\"100\":{\"id\":\"/docs/catalog-8\",\"page_id\":\"/docs/catalog\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/catalog#vouchers\",\"content\":\"Vouchers\"},\"101\":{\"id\":\"/docs/catalog-9\",\"page_id\":\"/docs/catalog\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/catalog#creating-a-voucher\",\"content\":\"Creating a voucher\"},\"102\":{\"id\":\"/docs/catalog-10\",\"page_id\":\"/docs/catalog\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/catalog#stock-audit\",\"content\":\"Stock Audit\"},\"103\":{\"id\":\"/docs/catalog-11\",\"page_id\":\"/docs/catalog\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/catalog#step-1--stock-session\",\"content\":\"Step 1 — Stock Session\"},\"104\":{\"id\":\"/docs/catalog-12\",\"page_id\":\"/docs/catalog\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/catalog#step-2--stock-entry-counting\",\"content\":\"Step 2 — Stock Entry (Counting)\"},\"105\":{\"id\":\"/docs/catalog-13\",\"page_id\":\"/docs/catalog\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/catalog#step-3--stock-review\",\"content\":\"Step 3 — Stock Review\"},\"106\":{\"id\":\"/docs/catalog-14\",\"page_id\":\"/docs/catalog\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/catalog#catalog-overview\",\"content\":\"Catalog overview\"},\"107\":{\"id\":\"/docs/catalog-15\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog\",\"content\":\"The Catalog is where you define everything your salon offers — the services your team performs, the products you sell, membership packages, gift vouchers, and your product inventory. Think of it as the foundation that powers your bookings and checkout.\"},\"108\":{\"id\":\"/docs/catalog-16\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog\",\"content\":\"Click **Catalog** in the left menu to get started. You'll see five tabs at the top: **Services**, **Products**, **Memberships**, **Vouchers**, and **Stock Audit**.\"},\"109\":{\"id\":\"/docs/catalog-17\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#services\",\"content\":\"Services are the treatments your team performs — haircuts, color, manicures, massages, and so on. Every service you add here will be available to select when booking an appointment.\"},\"110\":{\"id\":\"/docs/catalog-18\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#adding-a-service\",\"content\":\"Go to **Catalog → Services** and click **Add Service**.\"},\"111\":{\"id\":\"/docs/catalog-19\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#adding-a-service\",\"content\":\"Give the service a **name**, choose a **category** (e.g., Hair, Nails), set the **duration** in minutes, and enter the **price**.\"},\"112\":{\"id\":\"/docs/catalog-20\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#adding-a-service\",\"content\":\"Make sure the status is set to **Active** — only active services show up when booking.\"},\"113\":{\"id\":\"/docs/catalog-21\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#adding-a-service\",\"content\":\"Click **Save**.\"},\"114\":{\"id\":\"/docs/catalog-22\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#editing-or-removing-a-service\",\"content\":\"Click the **Edit** icon on any service to update its details. If you want to stop a service from showing up in bookings without deleting it permanently, just toggle the status to inactive. To remove it entirely, use the **Delete** option.\"},\"115\":{\"id\":\"/docs/catalog-23\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#products\",\"content\":\"Products are the retail or consumable items you sell or use in your salon — shampoos, styling products, skincare, and so on. NxCut tracks your stock levels automatically as products are sold.\"},\"116\":{\"id\":\"/docs/catalog-24\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#adding-a-product\",\"content\":\"Go to **Catalog → Products** and click **Add Product**.\"},\"117\":{\"id\":\"/docs/catalog-25\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#adding-a-product\",\"content\":\"Enter the product's **name**, **brand**, **category**, and **supplier**.\"},\"118\":{\"id\":\"/docs/catalog-26\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#adding-a-product\",\"content\":\"Set the **price** and enter your current **stock quantity**.\"},\"119\":{\"id\":\"/docs/catalog-27\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#adding-a-product\",\"content\":\"Toggle it to **Active** so it's available to add during checkout.\"},\"120\":{\"id\":\"/docs/catalog-28\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#adding-a-product\",\"content\":\"Click **Save**.\"},\"121\":{\"id\":\"/docs/catalog-29\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#adding-a-product\",\"content\":\"Every time a product is sold at checkout, your stock count goes down automatically. Use the Stock Audit tab when you want to check your physical stock against what the system shows.\"},\"122\":{\"id\":\"/docs/catalog-30\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#memberships\",\"content\":\"Memberships are prepaid session packages — a client pays upfront for a bundle of appointments (for example, 10 haircuts for the price of 8). Each time they come in and use a session, it's deducted from their balance automatically.\"},\"123\":{\"id\":\"/docs/catalog-31\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#creating-a-membership\",\"content\":\"Go to **Catalog → Memberships** and click **Add Membership**.\"},\"124\":{\"id\":\"/docs/catalog-32\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#creating-a-membership\",\"content\":\"Give the membership a **name** and choose which **service** it applies to.\"},\"125\":{\"id\":\"/docs/catalog-33\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#creating-a-membership\",\"content\":\"Set the number of **sessions** included and the total **price**.\"},\"126\":{\"id\":\"/docs/catalog-34\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#creating-a-membership\",\"content\":\"Optionally set an **expiry period** — for example, all sessions must be used within 12 months of purchase.\"},\"127\":{\"id\":\"/docs/catalog-35\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#creating-a-membership\",\"content\":\"Click **Save**.\"},\"128\":{\"id\":\"/docs/catalog-36\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#creating-a-membership\",\"content\":\"Once a client buys a membership at checkout, their session count is tracked automatically on their client profile. Sessions are used up each time they check out using that membership.\"},\"129\":{\"id\":\"/docs/catalog-37\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#vouchers\",\"content\":\"Vouchers are gift cards or discount codes that clients can redeem when paying for services or products. You set the value (either a fixed amount or a percentage off), and NxCut tracks how much has been used and what's left.\"},\"130\":{\"id\":\"/docs/catalog-38\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#creating-a-voucher\",\"content\":\"Go to **Catalog → Vouchers** and click **Add Voucher**.\"},\"131\":{\"id\":\"/docs/catalog-39\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#creating-a-voucher\",\"content\":\"Give the voucher a **name** and choose the discount type: a **fixed amount** (e.g., AED 100 off) or a **percentage** (e.g., 20% off).\"},\"132\":{\"id\":\"/docs/catalog-40\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#creating-a-voucher\",\"content\":\"Create a **voucher code** — this is what the client enters at checkout.\"},\"133\":{\"id\":\"/docs/catalog-41\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#creating-a-voucher\",\"content\":\"Optionally set an **expiry date** and a **usage limit** (e.g., can only be used once).\"},\"134\":{\"id\":\"/docs/catalog-42\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#creating-a-voucher\",\"content\":\"Click **Save**.\"},\"135\":{\"id\":\"/docs/catalog-43\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#creating-a-voucher\",\"content\":\"You can check a client's remaining voucher balance and full usage history on their profile under Clients → Voucher Activity.\"},\"136\":{\"id\":\"/docs/catalog-44\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#stock-audit\",\"content\":\"A stock audit is how you check that your physical inventory matches what NxCut thinks you have. It's good practice to run one regularly, especially if products are used during services as well as sold.\"},\"137\":{\"id\":\"/docs/catalog-45\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#stock-audit\",\"content\":\"A stock audit moves through three stages: **Stock Session → Stock Entry → Stock Review**. Each stage has its own status so you always know where an audit is up to.\"},\"138\":{\"id\":\"/docs/catalog-46\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#stock-audit\",\"content\":\"Status\"},\"139\":{\"id\":\"/docs/catalog-47\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#stock-audit\",\"content\":\"What it means\"},\"140\":{\"id\":\"/docs/catalog-48\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#stock-audit\",\"content\":\"In Progress\"},\"141\":{\"id\":\"/docs/catalog-49\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#stock-audit\",\"content\":\"The audit is open and items are being counted\"},\"142\":{\"id\":\"/docs/catalog-50\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#stock-audit\",\"content\":\"Review\"},\"143\":{\"id\":\"/docs/catalog-51\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#stock-audit\",\"content\":\"Counting is done — ready to review and confirm\"},\"144\":{\"id\":\"/docs/catalog-52\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#stock-audit\",\"content\":\"Completed\"},\"145\":{\"id\":\"/docs/catalog-53\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#stock-audit\",\"content\":\"The audit is finalised and can no longer be edited\"},\"146\":{\"id\":\"/docs/catalog-54\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#step-1--stock-session\",\"content\":\"Go to **Catalog → Stock Audit** and click **Start New Audit Session**.\"},\"147\":{\"id\":\"/docs/catalog-55\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#step-1--stock-session\",\"content\":\"Select the products you want to include in this count.\"},\"148\":{\"id\":\"/docs/catalog-56\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#step-1--stock-session\",\"content\":\"Click **Start** to begin. The audit moves to the **Stock Entry** stage.\"},\"149\":{\"id\":\"/docs/catalog-57\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#step-2--stock-entry-counting\",\"content\":\"This is where you physically count your stock. The entry screen opens in **barcode mode** by default — just scan a product's barcode and NxCut will find it automatically and add 1 to its counted quantity. Each scan is saved instantly, so you don't need to do anything extra.\"},\"150\":{\"id\":\"/docs/catalog-58\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#step-2--stock-entry-counting\",\"content\":\"Scan the same product multiple times to keep adding to its count — each scan increments the quantity by 1.\"},\"151\":{\"id\":\"/docs/catalog-59\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#step-2--stock-entry-counting\",\"content\":\"**If you click Save Stock Audit before finishing:**\"},\"152\":{\"id\":\"/docs/catalog-60\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#step-2--stock-entry-counting\",\"content\":\"A dialog will appear telling you how many products still haven't been counted (e.g., \\\"5 products remaining\\\"). The only option here is **Continue** — this sends you back to finish counting before the audit can be saved.\"},\"153\":{\"id\":\"/docs/catalog-61\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#step-2--stock-entry-counting\",\"content\":\"**If you click the X (close) button before finishing:**\"},\"154\":{\"id\":\"/docs/catalog-62\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#step-2--stock-entry-counting\",\"content\":\"A dialog titled &#x2A;*\\\"Uncounted products remaining\\\"** will appear, asking how you'd like to handle the items you didn't get to. You'll have two choices:\"},\"155\":{\"id\":\"/docs/catalog-63\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#step-2--stock-entry-counting\",\"content\":\"**Save uncounted as 0** — records those products as having zero stock on the shelf. Use this if you genuinely checked and found nothing.\"},\"156\":{\"id\":\"/docs/catalog-64\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#step-2--stock-entry-counting\",\"content\":\"**Sync counted to previous stock** — leaves those products at whatever stock value was already in the system. Use this if you simply didn't get around to counting them and don't want to affect their records.\"},\"157\":{\"id\":\"/docs/catalog-65\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#step-2--stock-entry-counting\",\"content\":\"Not sure which to pick? If you didn't actually check those products, choose **Sync counted to previous stock** — that way only the items you physically counted will be updated.\"},\"158\":{\"id\":\"/docs/catalog-66\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#step-3--stock-review\",\"content\":\"Once all items are counted and saved, the audit moves to **Review** status. On this page you'll see:\"},\"159\":{\"id\":\"/docs/catalog-67\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#step-3--stock-review\",\"content\":\"An overview of every product that was counted\"},\"160\":{\"id\":\"/docs/catalog-68\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#step-3--stock-review\",\"content\":\"The **quantity difference** between what the system expected and what you physically counted\"},\"161\":{\"id\":\"/docs/catalog-69\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#step-3--stock-review\",\"content\":\"The **price difference** — the value impact of any discrepancies\"},\"162\":{\"id\":\"/docs/catalog-70\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#step-3--stock-review\",\"content\":\"From here you can:\"},\"163\":{\"id\":\"/docs/catalog-71\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#step-3--stock-review\",\"content\":\"**Resume editing** — go back and adjust any counts before finalising\"},\"164\":{\"id\":\"/docs/catalog-72\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#step-3--stock-review\",\"content\":\"**Complete the audit** — confirm the counts are correct and lock the audit\"},\"165\":{\"id\":\"/docs/catalog-73\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#step-3--stock-review\",\"content\":\"Once you click **Complete**, the audit is finalised and cannot be edited. Make sure everything looks right before confirming.\"},\"166\":{\"id\":\"/docs/catalog-74\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#catalog-overview\",\"content\":\"Tab\"},\"167\":{\"id\":\"/docs/catalog-75\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#catalog-overview\",\"content\":\"What it's for\"},\"168\":{\"id\":\"/docs/catalog-76\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#catalog-overview\",\"content\":\"Services\"},\"169\":{\"id\":\"/docs/catalog-77\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#catalog-overview\",\"content\":\"The treatments your team performs\"},\"170\":{\"id\":\"/docs/catalog-78\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#catalog-overview\",\"content\":\"Products\"},\"171\":{\"id\":\"/docs/catalog-79\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#catalog-overview\",\"content\":\"Retail and consumable items, with automatic stock tracking\"},\"172\":{\"id\":\"/docs/catalog-80\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#catalog-overview\",\"content\":\"Memberships\"},\"173\":{\"id\":\"/docs/catalog-81\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#catalog-overview\",\"content\":\"Prepaid session bundles for specific services\"},\"174\":{\"id\":\"/docs/catalog-82\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#catalog-overview\",\"content\":\"Vouchers\"},\"175\":{\"id\":\"/docs/catalog-83\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#catalog-overview\",\"content\":\"Gift cards and discount codes\"},\"176\":{\"id\":\"/docs/catalog-84\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#catalog-overview\",\"content\":\"Stock Audit\"},\"177\":{\"id\":\"/docs/catalog-85\",\"page_id\":\"/docs/catalog\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/catalog#catalog-overview\",\"content\":\"Count your physical stock and spot any discrepancies\"},\"178\":{\"id\":\"/docs/checkout\",\"page_id\":\"/docs/checkout\",\"type\":\"page\",\"content\":\"Checkout\",\"breadcrumbs\":[\"Docs\"],\"tags\":[],\"url\":\"/docs/checkout\"},\"179\":{\"id\":\"/docs/checkout-0\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout\",\"content\":\"Collect payment, print receipts, and manage completed sales\"},\"180\":{\"id\":\"/docs/checkout-1\",\"page_id\":\"/docs/checkout\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/checkout#starting-a-checkout\",\"content\":\"Starting a checkout\"},\"181\":{\"id\":\"/docs/checkout-2\",\"page_id\":\"/docs/checkout\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/checkout#the-checkout-screen\",\"content\":\"The checkout screen\"},\"182\":{\"id\":\"/docs/checkout-3\",\"page_id\":\"/docs/checkout\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/checkout#applying-discounts-tips-and-vouchers\",\"content\":\"Applying discounts, tips, and vouchers\"},\"183\":{\"id\":\"/docs/checkout-4\",\"page_id\":\"/docs/checkout\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/checkout#completing-the-payment\",\"content\":\"Completing the payment\"},\"184\":{\"id\":\"/docs/checkout-5\",\"page_id\":\"/docs/checkout\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/checkout#sale-receipt\",\"content\":\"Sale receipt\"},\"185\":{\"id\":\"/docs/checkout-6\",\"page_id\":\"/docs/checkout\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/checkout#print-the-receipt\",\"content\":\"Print the receipt\"},\"186\":{\"id\":\"/docs/checkout-7\",\"page_id\":\"/docs/checkout\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/checkout#view-the-clients-profile\",\"content\":\"View the client's profile\"},\"187\":{\"id\":\"/docs/checkout-8\",\"page_id\":\"/docs/checkout\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/checkout#void-a-sale\",\"content\":\"Void a sale\"},\"188\":{\"id\":\"/docs/checkout-9\",\"page_id\":\"/docs/checkout\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/checkout#checkout-summary\",\"content\":\"Checkout summary\"},\"189\":{\"id\":\"/docs/checkout-10\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout\",\"content\":\"Checkout is how you collect payment after a client's visit. The whole process happens in a panel that slides in from the right — no page navigation needed.\"},\"190\":{\"id\":\"/docs/checkout-11\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#starting-a-checkout\",\"content\":\"On the Calendar, click on the appointment card you want to check out.\"},\"191\":{\"id\":\"/docs/checkout-12\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#starting-a-checkout\",\"content\":\"In the **Edit Appointment** panel that opens, click the **Checkout** button at the bottom right.\"},\"192\":{\"id\":\"/docs/checkout-13\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#starting-a-checkout\",\"content\":\"The checkout screen slides in from the right, showing the client's name and the services from the appointment already loaded.\"},\"193\":{\"id\":\"/docs/checkout-14\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#the-checkout-screen\",\"content\":\"The checkout screen is split into two areas:\"},\"194\":{\"id\":\"/docs/checkout-15\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#the-checkout-screen\",\"content\":\"**Left — Payment**\\r\\nChoose how the client is paying. The available options are shown as cards:\"},\"195\":{\"id\":\"/docs/checkout-16\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#the-checkout-screen\",\"content\":\"Option\"},\"196\":{\"id\":\"/docs/checkout-17\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#the-checkout-screen\",\"content\":\"Description\"},\"197\":{\"id\":\"/docs/checkout-18\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#the-checkout-screen\",\"content\":\"**Card**\"},\"198\":{\"id\":\"/docs/checkout-19\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#the-checkout-screen\",\"content\":\"Credit or debit card\"},\"199\":{\"id\":\"/docs/checkout-20\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#the-checkout-screen\",\"content\":\"**Cash**\"},\"200\":{\"id\":\"/docs/checkout-21\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#the-checkout-screen\",\"content\":\"Pay with cash\"},\"201\":{\"id\":\"/docs/checkout-22\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#the-checkout-screen\",\"content\":\"**Membership**\"},\"202\":{\"id\":\"/docs/checkout-23\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#the-checkout-screen\",\"content\":\"Redeem a pre-paid session from the client's membership\"},\"203\":{\"id\":\"/docs/checkout-24\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#the-checkout-screen\",\"content\":\"**Online**\"},\"204\":{\"id\":\"/docs/checkout-25\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#the-checkout-screen\",\"content\":\"Online payment\"},\"205\":{\"id\":\"/docs/checkout-26\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#the-checkout-screen\",\"content\":\"**Split Payment**\"},\"206\":{\"id\":\"/docs/checkout-27\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#the-checkout-screen\",\"content\":\"Divide the bill across more than one payment method\"},\"207\":{\"id\":\"/docs/checkout-28\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#the-checkout-screen\",\"content\":\"Click the option that applies. The selected method will be highlighted.\"},\"208\":{\"id\":\"/docs/checkout-29\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#the-checkout-screen\",\"content\":\"**Right — Order summary**\\r\\nShows the client's name and phone number, the services being charged, and a full summary:\"},\"209\":{\"id\":\"/docs/checkout-30\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#the-checkout-screen\",\"content\":\"Total amount (excluding discounts)\"},\"210\":{\"id\":\"/docs/checkout-31\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#the-checkout-screen\",\"content\":\"Subtotal (after any discount)\"},\"211\":{\"id\":\"/docs/checkout-32\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#the-checkout-screen\",\"content\":\"VAT (5%)\"},\"212\":{\"id\":\"/docs/checkout-33\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#the-checkout-screen\",\"content\":\"**Total due**\"},\"213\":{\"id\":\"/docs/checkout-34\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#the-checkout-screen\",\"content\":\"The chosen payment method and amount\"},\"214\":{\"id\":\"/docs/checkout-35\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#applying-discounts-tips-and-vouchers\",\"content\":\"At the bottom left of the checkout screen, click the &#x2A;*···** (three dots) button to reveal additional options:\"},\"215\":{\"id\":\"/docs/checkout-36\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#applying-discounts-tips-and-vouchers\",\"content\":\"Option\"},\"216\":{\"id\":\"/docs/checkout-37\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#applying-discounts-tips-and-vouchers\",\"content\":\"What it does\"},\"217\":{\"id\":\"/docs/checkout-38\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#applying-discounts-tips-and-vouchers\",\"content\":\"**Apply Discount**\"},\"218\":{\"id\":\"/docs/checkout-39\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#applying-discounts-tips-and-vouchers\",\"content\":\"Add a fixed or percentage discount to the sale\"},\"219\":{\"id\":\"/docs/checkout-40\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#applying-discounts-tips-and-vouchers\",\"content\":\"**Add Tip**\"},\"220\":{\"id\":\"/docs/checkout-41\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#applying-discounts-tips-and-vouchers\",\"content\":\"Add a gratuity for the staff member\"},\"221\":{\"id\":\"/docs/checkout-42\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#applying-discounts-tips-and-vouchers\",\"content\":\"**Split Payment**\"},\"222\":{\"id\":\"/docs/checkout-43\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#applying-discounts-tips-and-vouchers\",\"content\":\"Divide the total across multiple payment methods\"},\"223\":{\"id\":\"/docs/checkout-44\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#applying-discounts-tips-and-vouchers\",\"content\":\"**Apply Voucher**\"},\"224\":{\"id\":\"/docs/checkout-45\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#applying-discounts-tips-and-vouchers\",\"content\":\"Redeem a voucher code to reduce the balance\"},\"225\":{\"id\":\"/docs/checkout-46\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#completing-the-payment\",\"content\":\"Once you've selected the payment method and applied any discounts or tips, click the &#x2A;*Pay AED \\\\[amount]** button at the bottom right to finalise the sale.\"},\"226\":{\"id\":\"/docs/checkout-47\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#sale-receipt\",\"content\":\"After payment is confirmed, the **Sale Receipt** screen appears. The header turns green and shows a **Paid** badge confirming the transaction is complete.\"},\"227\":{\"id\":\"/docs/checkout-48\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#sale-receipt\",\"content\":\"From here you can:\"},\"228\":{\"id\":\"/docs/checkout-49\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#print-the-receipt\",\"content\":\"Click the **print icon** (or the document icon for A4) to open the **Invoice Preview**. You'll see two format options:\"},\"229\":{\"id\":\"/docs/checkout-50\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#print-the-receipt\",\"content\":\"**Thermal Receipt (80mm)** — formatted for a POS receipt printer\"},\"230\":{\"id\":\"/docs/checkout-51\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#print-the-receipt\",\"content\":\"**Standard Invoice (A4)** — a full-page formatted tax invoice\"},\"231\":{\"id\":\"/docs/checkout-52\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#print-the-receipt\",\"content\":\"Both formats show:\"},\"232\":{\"id\":\"/docs/checkout-53\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#print-the-receipt\",\"content\":\"Your salon name, TRN, and branch location\"},\"233\":{\"id\":\"/docs/checkout-54\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#print-the-receipt\",\"content\":\"Invoice number, date, time, and receptionist\"},\"234\":{\"id\":\"/docs/checkout-55\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#print-the-receipt\",\"content\":\"Customer name and phone\"},\"235\":{\"id\":\"/docs/checkout-56\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#print-the-receipt\",\"content\":\"Services performed and the staff team\"},\"236\":{\"id\":\"/docs/checkout-57\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#print-the-receipt\",\"content\":\"Subtotal, VAT (5%), and total\"},\"237\":{\"id\":\"/docs/checkout-58\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#print-the-receipt\",\"content\":\"How the sale was paid\"},\"238\":{\"id\":\"/docs/checkout-59\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#print-the-receipt\",\"content\":\"\\\"Thank you for your visit!\\\" at the bottom\"},\"239\":{\"id\":\"/docs/checkout-60\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#print-the-receipt\",\"content\":\"For **Thermal Receipt**, you can **Download PDF** or **Browser Print**.\\r\\nFor **Standard Invoice**, click **Print**.\"},\"240\":{\"id\":\"/docs/checkout-61\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#view-the-clients-profile\",\"content\":\"From the sale receipt screen you can navigate directly to the client's full profile to see their history, memberships, and vouchers.\"},\"241\":{\"id\":\"/docs/checkout-62\",\"page_id\":\"/docs/checko