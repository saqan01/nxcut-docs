\":\"text\",\"url\":\"/docs#finding-your-way-around\",\"content\":\"Business configuration\"},\"565\":{\"id\":\"/docs-46\",\"page_id\":\"/docs\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs#finding-your-way-around\",\"content\":\"Admins only\"},\"566\":{\"id\":\"/docs-47\",\"page_id\":\"/docs\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs#finding-your-way-around\",\"content\":\"**Admin vs. Staff** — Admin users can access everything. Regular staff only see what they need for their daily work: Calendar, Sales, Clients, Catalog, and Team.\"},\"567\":{\"id\":\"/docs/reporting\",\"page_id\":\"/docs/reporting\",\"type\":\"page\",\"content\":\"Reporting & Analytics\",\"breadcrumbs\":[\"Docs\"],\"tags\":[],\"url\":\"/docs/reporting\"},\"568\":{\"id\":\"/docs/reporting-0\",\"page_id\":\"/docs/reporting\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/reporting\",\"content\":\"Access all your salon reports — sales, finance, and team performance\"},\"569\":{\"id\":\"/docs/reporting-1\",\"page_id\":\"/docs/reporting\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/reporting#finding-a-report\",\"content\":\"Finding a report\"},\"570\":{\"id\":\"/docs/reporting-2\",\"page_id\":\"/docs/reporting\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/reporting#available-reports\",\"content\":\"Available reports\"},\"571\":{\"id\":\"/docs/reporting-3\",\"page_id\":\"/docs/reporting\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/reporting#performance-dashboard\",\"content\":\"Performance Dashboard\"},\"572\":{\"id\":\"/docs/reporting-4\",\"page_id\":\"/docs/reporting\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/reporting#sales-log\",\"content\":\"Sales Log\"},\"573\":{\"id\":\"/docs/reporting-5\",\"page_id\":\"/docs/reporting\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/reporting#finance-summary\",\"content\":\"Finance Summary\"},\"574\":{\"id\":\"/docs/reporting-6\",\"page_id\":\"/docs/reporting\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/reporting#payment-tra