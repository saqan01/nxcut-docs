\":\"/docs/checkout#checkout-summary\",\"content\":\"Discount, tip, split payment, or voucher\"},\"251\":{\"id\":\"/docs/checkout-72\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#checkout-summary\",\"content\":\"Click Pay\"},\"252\":{\"id\":\"/docs/checkout-73\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#checkout-summary\",\"content\":\"Sale is recorded and receipt screen appears\"},\"253\":{\"id\":\"/docs/checkout-74\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#checkout-summary\",\"content\":\"Print receipt\"},\"254\":{\"id\":\"/docs/checkout-75\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#checkout-summary\",\"content\":\"Choose Thermal (80mm) or Standard Invoice (A4)\"},\"255\":{\"id\":\"/docs/checkout-76\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#checkout-summary\",\"content\":\"Void Sale\"},\"256\":{\"id\":\"/docs/checkout-77\",\"page_id\":\"/docs/checkout\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/checkout#checkout-summary\",\"content\":\"Cancels and reverses the transaction if needed\"},\"257\":{\"id\":\"/docs/clients\",\"page_id\":\"/docs/clients\",\"type\":\"page\",\"content\":\"Clients\",\"breadcrumbs\":[\"Docs\"],\"tags\":[],\"url\":\"/docs/clients\"},\"258\":{\"id\":\"/docs/clients-0\",\"page_id\":\"/docs/clients\",\"tags\":[],\"type\":\"text\",\"url\":\"/docs/clients\",\"content\":\"Manage your client database — add, search, and view full client profiles\"},\"259\":{\"id\":\"/docs/clients-1\",\"page_id\":\"/docs/clients\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/clients#the-client-list\",\"content\":\"The client list\"},\"260\":{\"id\":\"/docs/clients-2\",\"page_id\":\"/docs/clients\",\"type\":\"heading\",\"tags\":[],\"url\":\"/docs/clients#adding-a-new-client\",\"content\":\"Adding a new client\"},\"261\":{\"id\":\"/docs/clients