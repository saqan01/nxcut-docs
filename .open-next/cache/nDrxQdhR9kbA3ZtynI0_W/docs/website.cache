acity-100\",\"aria-hidden\":true}]]}]\n28:[\"$\",\"p\",null,{\"children\":\"This section shows the contact details displayed to clients on your booking page — your email address and WhatsApp number. These are pulled from your profile automatically.\"}]\n29:[\"$\",\"hr\",null,{}]\n2a:[\"$\",\"h2\",null,{\"className\":\"flex scroll-m-28 flex-row items-center gap-2\",\"id\":\"how-the-client-booking-flow-works\",\"children\":[[\"$\",\"a\",null,{\"data-card\":\"\",\"href\":\"#how-the-client-booking-flow-works\",\"className\":\"peer\",\"children\":\"How the client booking flow works\"}],[\"$\",\"$L1c\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$d:props:children:3:props:children:12:props:children:1:props:iconNode\",\"className\":\"lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100\",\"aria-hidden\":true}]]}]\n2b:[\"$\",\"p\",null,{\"children\":\"When a client visits your booking page, they go through a simple step-by-step process:\"}]\n2c:[\"$\",\"h3\",null,{\"className\":\"flex scroll-m-28 flex-row items-center gap-2\",\"id\":\"step-1--select-a-location\",\"children\":[[\"$\",\"a\",null,{\"data-card\":\"\",\"href\":\"#step-1--select-a-location\",\"className\":\"peer\",\"children\":\"Step 1 — Select a location\"}],[\"$\",\"$L1c\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$d:props:children:3:props:children:12:props:children:1:props:iconNode\",\"className\":\"lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100\",\"aria-hidden\":true}]]}]\n2d:[\"$\",\"p\",null,{\"children\":\"The client picks which branch they want to visit. If you only have one location, this step is skipped automatically.\"}]\n2e:[\"$\",\"h3\",null,{\"className\":\"flex scroll-m-28 flex-row items-center gap-2\",\"id\":\"step-2--browse-the-price-menu\",\"children\":[[\"$\",\"a\",null,{\"data-card\":\"\",\"href\":\"#step-2--browse-the-price-menu\",\"className\":\"peer\",\"children\":\"Step 2 — Br