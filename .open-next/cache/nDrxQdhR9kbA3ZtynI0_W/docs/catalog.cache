ning\\\"\"}],\" will appear, asking how you'd like to handle the items you didn't get to. You'll have two choices:\"]}]\n2d:[\"$\",\"ul\",null,{\"children\":[\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Save uncounted as 0\"}],\" — records those products as having zero stock on the shelf. Use this if you genuinely checked and found nothing.\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Sync counted to previous stock\"}],\" — leaves those products at whatever stock value was already in the system. Use this if you simply didn't get around to counting them and don't want to affect their records.\"]}],\"\\n\"]}]\n2e:[\"$\",\"div\",null,{\"className\":\"flex gap-2 my-4 rounded-xl border bg-fd-card p-3 ps-1 text-sm text-fd-card-foreground shadow-md\",\"style\":{\"--callout-color\":\"var(--color-fd-info, var(--color-fd-muted))\"},\"children\":[[\"$\",\"div\",null,{\"role\":\"none\",\"className\":\"w-0.5 bg-(--callout-color)/50 rounded-sm\"}],[\"$\",\"$L8\",null,{\"iconNode\":\"$1c:props:children:1:props:iconNode\",\"className\":\"lucide-info size-5 -me-0.5 fill-(--callout-color) text-fd-card\"}],[\"$\",\"div\",null,{\"className\":\"flex flex-col gap-2 min-w-0 flex-1\",\"children\":[\"$undefined\",[\"$\",\"div\",null,{\"className\":\"text-fd-muted-foreground prose-no-margin empty:hidden\",\"children\":[\"$\",\"p\",null,{\"children\":[\"Not sure which to pick? If you didn't actually check those products, choose \",[\"$\",\"strong\",null,{\"children\":\"Sync counted to previous stock\"}],\" — that way only the items you physically counted will be updated.\"]}]}]]}]]}]\n2f:[\"$\",\"hr\",null,{}]\n30:[\"$\",\"h3\",null,{\"className\":\"flex scroll-m-28 flex-row items-center gap-2\",\"id\":\"step-3--stock-review\",\"children\":[[\"$\",\"a\",null,{\"data-card\":\"\",\"href\":\"#step-3--stock-review\",\"className\":\"peer\",\"children\":\"Step 3 — Stock Review\"}],[\"$\",\"$L8\",null,{\"iconNode\":\"$0:rsc